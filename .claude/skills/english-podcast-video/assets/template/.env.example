# Sao chép file này thành .env rồi điền khoá. .env đã được .gitignore.
# KHÔNG để khoá thật trong file .env.example này (nó bị git theo dõi).

# ElevenLabs (giọng tự nhiên cho hội thoại) — dùng với:
#   npm run dialogue:audio:eleven -- --data projects/<id>/dialogue.json
ELEVENLABS_API_KEY=
# (tuỳ chọn) ghi đè giọng mặc định 2 nhân vật bằng voice ID ElevenLabs:
# ELEVEN_VOICE_A=21m00Tcm4TlvDq8ikWAM   # nữ (A)
# ELEVEN_VOICE_B=pNInz6obpgDQGcFmaJgB   # nam (B)
# (tuỳ chọn) model / định dạng. Mặc định eleven_v3 (hỗ trợ audio tag cảm xúc
# [laughs] [whispers] [excited]...). Dùng eleven_multilingual_v2 nếu cần ổn định.
# ELEVENLABS_MODEL=eleven_v3
# ELEVENLABS_FORMAT=mp3_44100_128

# aivideoauto / gommo TTS (nhiều model: eleven_v3, minimax_*, omnivoice_v1...) — dùng với:
#   npm run dialogue:audio:gommo -- --data projects/<id>/dialogue.json
#   (rồi chạy dialogue:align để có words[] cho karaoke)
# GOMMO_ACCESS_TOKEN=
# GOMMO_DOMAIN=go-mmo
# GOMMO_TTS_MODEL=eleven_v3
# GOMMO_VOICE_A=
# GOMMO_VOICE_B=

# OpenAI TTS (định dạng câu đơn script.json, adapter generate-audio.ts)
# OPENAI_API_KEY=
# TTS_PROVIDER=openai
